{
  "_说明": "复制此文件为 feishu_config.json，填入你的飞书应用凭据。建表后运行 setup_feishu_tables.py 自动填充 table_id 和 field_id。",
  "app_id": "cli_xxxxxxxxxxxxx",
  "app_secret": "你的飞书应用 Secret",
  "app_token": "你的飞书多维表格 Base Token",
  "tables": {
    "用户表": {
      "table_id": "",
      "key_field": "姓名",
      "fields": {
        "姓名": "", "角色": "", "性别": "", "头像种子": "",
        "个人简介": "", "钱包地址": "", "密码哈希": "", "UID": "",
        "注册日期": "", "所属营期": "", "备注": ""
      }
    },
    "营地表": {
      "table_id": "",
      "key_field": "营期名称",
      "fields": {
        "营期名称": "", "时间范围": "", "开始日期": "", "结束日期": "",
        "持续天数": "", "营期状态": "", "备注": ""
      }
    },
    "任务表": {
      "table_id": "",
      "key_field": "任务名称",
      "fields": {
        "任务名称": "", "任务类型": "", "任务分类": "", "负责人": "",
        "开始日期": "", "截止日期": "", "确认人": "", "NT积分": "",
        "状态": "", "来源": "", "备注": "", "范围": "",
        "发布者": "", "发布日期": "", "最大可领人数": "",
        "可见范围": "", "审核人": "", "是否启用": "", "最低季数": "",
        "领取记录": ""
      }
    },
    "NT流水表": {
      "table_id": "",
      "key_field": "关联任务",
      "fields": {
        "类型": "", "发起方": "", "接收方": "", "金额": "",
        "关联任务": "", "日期": "", "确认人": "", "范围": ""
      }
    },
    "流水表": {
      "table_id": "",
      "key_field": "事由",
      "fields": {
        "日期": "", "类型": "", "事由": "", "金额": "",
        "货币": "", "关联人员": "", "备注": ""
      }
    },
    "预算表": {
      "table_id": "",
      "key_field": "项目名称",
      "fields": {
        "项目名称": "", "项目分类": "", "预算金额": "",
        "实际金额": "", "货币": "", "所属营期": "", "备注": ""
      }
    },
    "预算参数表": {
      "table_id": "",
      "key_field": "参数名",
      "fields": {
        "参数名": "", "参数值": "", "参数分类": "",
        "货币类型": "", "说明": "", "备注": ""
      }
    },
    "日程表": {
      "table_id": "",
      "key_field": "板块名称",
      "fields": {
        "记录类型": "", "天数序号": "", "日期": "", "星期": "",
        "时间段": "", "板块名称": "", "活动内容": "", "备注": ""
      }
    },
    "决策表": {
      "table_id": "",
      "key_field": "决策标题",
      "fields": {
        "决策标题": "", "决策类型": "", "提出人": "", "提出日期": "",
        "状态": "", "内容": "", "决议": "", "备注": ""
      }
    },
    "共建者卡片表": {
      "table_id": "",
      "key_field": "姓名",
      "fields": {
        "姓名": "", "角色": "", "头像种子": "", "寄语": "",
        "NT角色": "", "所属营期": "", "备注": ""
      }
    },
    "邀请码表": {
      "table_id": "",
      "key_field": "码值",
      "fields": {
        "码值": "", "类型": "", "状态": "", "创建日期": "", "备注": ""
      }
    }
  }
}
